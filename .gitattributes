# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts should always use LF line endings
*.sh text eol=lf

# Force LF for all text files
*.txt text eol=lf
*.md text eol=lf
*.json text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.conf text eol=lf
*.example text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary