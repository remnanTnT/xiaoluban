# 数据库配置示例
# 复制此文件为 .env 并修改相应配置

# 测试环境数据库（默认）
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=123456
DB_HOST=7.197.65.7
DB_PORT=5430

# 生产环境数据库配置
# DB_HOST=7.197.65.7
# DB_PORT=5431

# 数据库初始化说明
# 如果遇到 "column does not exist" 错误，请执行：
# PGPASSWORD=123456 psql -h 7.197.65.7 -p 5430 -U postgres -d postgres -f init_db.sql
# 详见 backend/docs/DATABASE_INIT.md